{
  "name": "slick",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=json --outputFile=reports/vitest-results.json; test_status=$?; node scripts/render-test-report.mjs; report_status=$?; if [ $test_status -ne 0 ]; then exit $test_status; fi; exit $report_status",
    "test:watch": "vitest",
    "test:workflows": "vitest run src/server/modules",
    "test:contracts": "vitest run src/server/http src/server/modules/automation",
    "verify:commit": "npm run lint && npm run typecheck && npm run test:ci",
    "verify": "npm run lint && npm run typecheck && npm run test:ci && npm run build",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "prepare": "npm run hooks:install",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "next": "^16.0.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.36.0",
    "eslint-config-next": "^16.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
